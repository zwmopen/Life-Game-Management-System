  "visualDesign": "<div class=\"neu-card\">\n<svg viewBox=\"0 0 1000 650\">\n      <g transform=\"translate(500, 325)\">\n        <!-- 逻辑门背景 -->\n        <path d=\"M-300,-150 L100,-150 L200,0 L100,150 L-300,150 Z\" fill=\"none\" stroke=\"var(--text-primary)\" stroke-width=\"2\" opacity=\"0.1\" />\n        \n        <!-- 0 与 1 的分叉流 -->\n        <g transform=\"translate(-400, 0)\">\n          <path d=\"M0,0 Q150,0 250,-100\" stroke=\"var(--danger)\" stroke-width=\"12\" fill=\"none\" opacity=\"0.8\">\n             <animate attributeName=\"stroke-dasharray\" from=\"0,400\" to=\"400,0\" dur=\"2s\" repeatCount=\"indefinite\" />\n          </path>\n          <path d=\"M0,0 Q150,0 250,100\" stroke=\"var(--success)\" stroke-width=\"12\" fill=\"none\" opacity=\"0.8\">\n             <animate attributeName=\"stroke-dasharray\" from=\"0,400\" to=\"400,0\" dur=\"2s\" begin=\"1s\" repeatCount=\"indefinite\" />\n          </path>\n        </g>\n\n        <!-- 决策点 -->\n        <g>\n          <rect x=\"-60\" y=\"-60\" width=\"120\" height=\"120\" rx=\"60\" fill=\"var(--danger)\" filter=\"drop-shadow(0 0 30px var(--danger))\" />\n          <text text-anchor=\"middle\" y=\"10\" fill=\"white\" style=\"font-size: 24px; font-weight: 900;\">ANd/OR</text>\n        </g>\n        \n        <!-- 结果 A (0) -->\n        <g transform=\"translate(300, -100)\">\n          <circle r=\"50\" fill=\"none\" stroke=\"var(--danger)\" stroke-width=\"4\" stroke-dasharray=\"5 5\" />\n          <text text-anchor=\"middle\" y=\"10\" fill=\"var(--danger)\" style=\"font-size: 32px; font-weight: 900;\">0 (假)</text>\n        </g>\n\n        <!-- 结果 B (1) -->\n        <g transform=\"translate(300, 100)\">\n          <circle r=\"60\" fill=\"var(--success)\" />\n          <text text-anchor=\"middle\" y=\"10\" fill=\"white\" style=\"font-size: 32px; font-weight: 900;\">1 (真)</text>\n          <circle r=\"80\" fill=\"none\" stroke=\"var(--success)\" stroke-width=\"2\" class=\"animate-ping\" />\n        </g>\n\n        <text y=\"260\" text-anchor=\"middle\" fill=\"var(--danger)\" style=\"font-size: 42px; font-weight: 900; letter-spacing: 0.2em;\">逻辑的极致还原</text>\n      </g>\n    </svg>\n</div>"
