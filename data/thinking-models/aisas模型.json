text y=\"70\" text-anchor=\"middle\" fill=\"var(--primary-color)\" style=\"font-size: 14px; font-weight: 800;\">行动</text>\n          </g>\n\n          <!-- Share 循环 -->\n          <g transform=\"translate(800, 0)\">\n            <circle r=\"55\" fill=\"var(--secondary-color)\" />\n            <text text-anchor=\"middle\" y=\"8\" fill=\"var(--text-primary)\" style=\"font-size: 20px; font-weight: 900;\">S</text>\n            <text y=\"80\" text-anchor=\"middle\" fill=\"var(--secondary-color)\" style=\"font-size: 14px; font-weight: 800;\">分享</text>\n            <circle r=\"70\" fill=\"none\" stroke=\"var(--secondary-color)\" stroke-width=\"1\" />\n          </g>\n\n          <!-- 闭环箭头 -->\n          <path d=\"M800,-80 Q400,-250 50,-80\" fill=\"none\" stroke=\"var(--primary-color)\" stroke-width=\"2\" stroke-dasharray=\"10 5\" opacity=\"0.2\" />\n        </g>\n      </svg>\n</div>"
