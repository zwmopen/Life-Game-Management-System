/g>\n      \n      <text x=\"500\" y=\"550\" text-anchor=\"middle\" fill=\"var(--text-secondary)\" style=\"font-size: 24px; font-weight: 900; letter-spacing: 0.3em; opacity: 0.2;\">非线性的持续迭代循环</text>\n    </svg>\n</div>"
