{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/webdav(.*)",
      "dest": "/api/webdav/$1"
    },
    {
      "src": "/webdav(.*)",
      "dest": "/api/webdav$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
