  "visualDesign": "<div class=\"neu-card\">\n<svg viewBox=\"0 0 1000 700\">\r\n      <!-- 网格背景 -->\r\n      <defs>\r\n        <pattern id=\"grid\" width=\"50\" height=\"50\" patternUnits=\"userSpaceOnUse\">\r\n          <path d=\"M 50 0 L 0 0 0 50\" fill=\"none\" stroke=\"#64748b\" stroke-opacity=\"0.1\" stroke-width=\"0.5\"/>\r\n        </pattern>\r\n      </defs>\r\n      <rect width=\"1000\" height=\"700\" fill=\"url(#grid)\" />\r\n      \r\n      <!-- 坐标轴 -->\r\n      <line x1=\"100\" y1=\"600\" x2=\"900\" y2=\"600\" stroke=\"#1e293b\" stroke-width=\"2\" />\r\n      <line x1=\"100\" y1=\"100\" x2=\"100\" y2=\"600\" stroke=\"#1e293b\" stroke-width=\"2\" />\r\n      \r\n      <!-- 坐标轴标注 -->\r\n      <text x=\"500\" y=\"630\" text-anchor=\"middle\" fill=\"#1e293b\" style=\"font-size: 14px; font-weight: 900;\">试验次数</text>\r\n      <text x=\"50\" y=\"350\" text-anchor=\"middle\" fill=\"#1e293b\" style=\"font-size: 14px; font-weight: 900; writing-mode: tb;\">事件频率</text>\r\n      \r\n      <!-- 期望均值线 -->\r\n      <line x1=\"100\" y1=\"350\" x2=\"900\" y2=\"350\" stroke=\"#10b981\" stroke-width=\"3\" stroke-dasharray=\"10 5\" />\r\n      <text x=\"920\" y=\"355\" fill=\"#10b981\" style=\"font-size: 14px; font-weight: 900;\">期望均值</text>\r\n      \r\n      <!-- 数据点 -->\r\n      <g>\r\n        <!-- 短期剧烈波动的数据点 -->\r\n        <circle cx=\"150\" cy=\"200\" r=\"6\" fill=\"#ef4444\" opacity=\"0.8\" />\r\n        <circle cx=\"200\" cy=\"500\" r=\"6\" fill=\"#ef4444\" opacity=\"0.8\" />\r\n        <circle cx=\"250\" cy=\"250\" r=\"6\" fill=\"#ef4444\" opacity=\"0.8\" />\r\n        <circle cx=\"300\" cy=\"450\" r=\"6\" fill=\"#ef4444\" opacity=\"0.8\" />\r\n        <circle cx=\"350\" cy=\"300\" r=\"6\" fill=\"#ef4444\" opacity=\"0.8\" />\r\n        \r\n        <!-- 中期逐渐平稳的数据点 -->\r\n        <circle cx=\"400\" cy=\"380\" r=\"6\" fill=\"#f59e0b\" opacity=\"0.8\" />\r\n        <circle cx=\"450\" cy=\"320\" r=\"6\" fill=\"#f59e0b\" opacity=\"0.8\" />\r\n        <circle cx=\"500\" cy=\"360\" r=\"6\" fill=\"#f59e0b\" opacity=\"0.8\" />\r\n        <circle cx=\"550\" cy=\"340\" r=\"6\" fill=\"#f59e0b\" opacity=\"0.8\" />\r\n        \r\n        <!-- 长期稳定的数据点 -->\r\n        <circle cx=\"600\" cy=\"355\" r=\"6\" fill=\"#10b981\" opacity=\"0.8\" />\r\n        <circle cx=\"650\" cy=\"345\" r=\"6\" fill=\"#10b981\" opacity=\"0.8\" />\r\n        <circle cx=\"700\" cy=\"352\" r=\"6\" fill=\"#10b981\" opacity=\"0.8\" />\r\n        <circle cx=\"750\" cy=\"348\" r=\"6\" fill=\"#10b981\" opacity=\"0.8\" />\r\n        <circle cx=\"800\" cy=\"350\" r=\"6\" fill=\"#10b981\" opacity=\"0.8\" />\r\n      </g>\r\n      \r\n      <!-- 波动曲线 (从剧烈到平稳) -->\r\n      <path d=\"M100,350 L150,200 L200,500 L250,250 L300,450 L350,300 L400,380 L450,320 L500,360 L550,340 L600,355 L650,345 L700,352 L750,348 L800,350 L900,350\" \r\n            fill=\"none\" stroke=\"#ef4444\" stroke-width=\"3\" stroke-linecap=\"round\">\r\n        <animate attributeName=\"stroke-dasharray\" from=\"0,2000\" to=\"2000,0\" dur=\"5s\" fill=\"freeze\" />\r\n      </path>\r\n\r\n      <!-- 波动范围阴影 -->\r\n      <path d=\"M100,350 L150,200 L200,500 L250,250 L300,450 L350,300 L400,380 L450,320 L500,360 L550,340 L600,355 L650,345 L700,352 L750,348 L800,350 L900,350 L900,350 L100,350\" \r\n            fill=\"#ef4444\" opacity=\"0.1\" />\r\n      \r\n      <!-- 动态试验次数指示器 -->\r\n      <g>\r\n        <rect x=\"850\" y=\"50\" width=\"100\" height=\"40\" rx=\"20\" fill=\"#ef4444\" />\r\n        <text x=\"900\" y=\"78\" text-anchor=\"middle\" fill=\"white\" style=\"font-size: 16px; font-weight: 900;\">N=0</text>\r\n        <animate attributeName=\"x\" values=\"100;900\" dur=\"5s\" fill=\"freeze\" />\r\n        <animate attributeName=\"fill\" values=\"#ef4444;#f59e0b;#10b981\" dur=\"5s\" fill=\"freeze\" />\r\n      </g>\r\n\r\n      <!-- 标注 -->\r\n      <g transform=\"translate(200, 550)\">\r\n        <rect x=\"-80\" y=\"-25\" width=\"160\" height=\"50\" rx=\"25\" fill=\"#ef4444\" opacity=\"0.1\" />\r\n        <text t