idth=\"6\" />\n            <text text-anchor=\"middle\" y=\"5\" fill=\"var(--primary-color)\" style=\"font-size: 32px; font-weight: 900;\">多元化</text>\n            <text text-anchor=\"middle\" y=\"45\" fill=\"var(--primary-color)\" style=\"font-size: 18px; font-weight: 900;\">(极高风险区)</text>\n          </g>\n\n          <!-- 坐标轴 -->\n          <text x=\"330\" y=\"5\" fill=\"var(--text-secondary)\" style=\"font-size: 18px; font-weight: 900; opacity: 0.3;\">产品: 新 →</text>\n          <text x=\"0\" y=\"-280\" text-anchor=\"middle\" fill=\"var(--text-secondary)\" style=\"font-size: 18px; font-weight: 900; opacity: 0.3;\">市场: 现有 ↑</text>\n        </g>\n      </svg>\n</div>"
