44\" filter=\"drop-shadow(0 0 40px #ef4444)\" />\r\n          <text y=\"15\" text-anchor=\"middle\" fill=\"white\" style=\"font-size: 48px; font-weight: 900;\">意愿</text>\r\n          <text y=\"55\" text-anchor=\"middle\" fill=\"white\" style=\"font-size: 12px; font-weight: 800;\">(Will)</text>\r\n          <circle r=\"130\" fill=\"none\" stroke=\"#ef4444\" stroke-width=\"2\" class=\"animate-ping\" />\r\n        </g>\r\n      </g>\r\n      <text x=\"600\" y=\"100\" text-anchor=\"middle\" fill=\"#ef4444\" style=\"font-size: 20px; font-weight: 900; letter-spacing: 0.3em; opacity: 0.2;\">教练进化</text>\r\n    </svg>\n</div>"
